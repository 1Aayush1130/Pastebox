{
  "name": "pastebox",
  "version": "1.0.0",
  "description": "PasteBox - Full-stack file sharing application",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm install --prefix client",
    "build": "npm run build --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nanoid": "^3.3.7",
    "nodemon": "^3.0.2",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1"
  },
  "keywords": ["file-sharing", "mern", "pastebox"],
  "author": "PasteBox",
  "license": "MIT"
}
